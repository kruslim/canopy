# Copy this file to `.env` and paste your key. `.env` is gitignored — the key never
# enters the tree or git history (Constraint 2 hygiene applies to secrets too).
#
# Get a FREE Gemini API key (no credit card) at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Optional — only needed if you run `scripts/ask.py --provider anthropic`.
# ANTHROPIC_API_KEY=
